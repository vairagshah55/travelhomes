# =========================================================================
# .env.example — copy to .env and fill in real values. NEVER commit .env.
# =========================================================================

# --- App ---
NODE_ENV=development
PORT=3001

# --- Database ---
# Either MONGO_URI or MONGODB_URI is read; prefer MONGO_URI.
MONGO_URI=mongodb://127.0.0.1:27017/travelhomes
# Optional: override db name without changing the URI
MONGO_DB_NAME=

# --- Auth / JWT ---
# REQUIRED. App will refuse to boot without a strong secret.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_SECRET_FOR_VERIFY=
JWT_EXPIRES_IN=7d
SESSION_SECRET=

# --- Frontend / Admin URLs (used in CORS + email links) ---
FRONTEND_URL=http://localhost:8080
ADMIN_URL=http://localhost:8081
STORE_URL=http://localhost:8080

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# --- Razorpay ---
RAZOR_KEY=
RAZOR_SECRET=

# --- Twilio (SMS / OTP) ---
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Email (SMTP) ---
# The codebase reads several aliases. Set one consistent set:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# Legacy aliases — kept until callers are unified:
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_ENCRYPTION=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_SENDER=

# --- Marketing (Facebook) ---
FB_PAGE_ACCESS_TOKEN=

# --- Debug toggles (leave false in production) ---
LOG_AUTH_DEBUG=false
LOG_OTP_DEBUG=false
